# Copy to .env.backend-dev (or export these vars) before running docker compose.

# Ports published on host
BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5432

# Optional source mounts (only if you uncomment them in docker-compose.backend-dev.yml)
# BACKEND_SOURCE_DIR=./backend
MODULES_SOURCE_DIR=./backend/modules
FILESTORE_SOURCE_DIR=./filestore

# Official Postgres image credentials
POSTGRES_DB=licium
POSTGRES_USER=licium
POSTGRES_PASSWORD=licium_dev_password

# Frontend runtime image (can be project/flavor image)
FRONTEND_IMAGE=registry.gitlab.com/licium/community/ci-cd/frontend:latest

# Backend auth secret (persist it to keep sessions valid across restarts)
AUTH_SECRET_KEY=change-this-dev-secret

# Frontend -> backend URLs
NUXT_PUBLIC_API_BASE=http://localhost:8000/api
NUXT_API_BASE_INTERNAL=http://backend:8000/api

# Optional tuning
LICIUM_THEMES_AUTOSYNC=1
LICIUM_DB_POOL_SIZE=20
LICIUM_DB_MAX_OVERFLOW=40
LICIUM_DB_POOL_TIMEOUT=10
LICIUM_DB_POOL_RECYCLE=1800
